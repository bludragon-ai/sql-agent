# ── LLM Provider ─────────────────────────────────────────────
# Options: "anthropic" | "openai"
LLM_PROVIDER=anthropic

# ── API Keys (set the one matching your provider) ───────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# ── Model Override (optional) ────────────────────────────────
# Leave blank to use sensible defaults per provider.
# Anthropic default: claude-sonnet-4-20250514
# OpenAI default:    gpt-4o
LLM_MODEL=

# ── Database ─────────────────────────────────────────────────
# Path to the SQLite database file.
DATABASE_PATH=data/sample.db

# ── Safety ───────────────────────────────────────────────────
# Allow write operations (INSERT, UPDATE, DELETE, DROP, etc.)
# Default: false — only SELECT queries are permitted.
ALLOW_WRITE_QUERIES=false

# ── Streamlit ────────────────────────────────────────────────
STREAMLIT_PORT=8501
